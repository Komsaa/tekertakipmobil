{
  "expo": {
    "name": "TakerTakip",
    "slug": "tekertakip-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2437"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tekertakip.driver"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B2437"
      },
      "package": "com.tekertakip.driver",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "TakerTakip fiş fotoğrafı çekmek için kameraya erişim istiyor.",
          "cameraPermission": "TakerTakip fiş fotoğrafı çekmek için kameraya erişim istiyor."
        }
      ]
    ]
  }
}
